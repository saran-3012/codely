# ── Database ─────────────────────────────────────────────────────────────────
# Docker Compose (Oracle Cloud — all services in one compose):
DATABASE_URL="postgresql://codely:codely_secret@db:5432/codely"

# ── Auth secrets (required) ───────────────────────────────────────────────────
JWT_SECRET="change-this-to-a-long-random-secret"
REFRESH_TOKEN_SECRET="change-this-to-another-long-random-secret"

# ── CORS — allowed frontend origins ──────────────────────────────────────────
# Development default (set in app.config.json, no need to set here):
#   FRONTEND_URL=http://localhost:5173,http://localhost:5174
# Production (single Oracle Cloud host — nginx serves on port 80):
# FRONTEND_URL=http://<your-oracle-vm-ip>

# ── Code execution ────────────────────────────────────────────────────────────
# Self-hosted Piston (Docker Compose default — piston service in compose.yml):
PISTON_URL=http://piston:2000/api/v2
# If Piston is unreachable, the backend automatically falls back to a
# sandboxed local execution environment with the following restrictions:
#   - No host secrets exposed (DATABASE_URL, JWT_SECRET etc. stripped)
#   - HOME redirected to tmpdir (blocks ~/.ssh, ~/.aws access)
#   - Virtual memory cap: 256 MB
#   - File write cap: 10 MB
#   - CPU time cap: EXEC_TIMEOUT_MS / 1000 seconds
#   - Max processes (fork bomb protection): 32
#   - Max file descriptors: 64
#   - Output cap: 100 KB
#   (ulimit restrictions are Linux-only; no-ops on macOS dev machines)

# ── Optional tunables ─────────────────────────────────────────────────────────
# (defaults set in app.config.json — only override here if needed)
# EXEC_TIMEOUT_MS=10000
# RATE_LIMIT_WINDOW_MS=900000
# RATE_LIMIT_MAX=10
