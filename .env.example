# ── Auth secrets (required) ─────────────────────────────────────────────────
JWT_SECRET=replace-with-a-long-random-secret-min-32-chars
REFRESH_TOKEN_SECRET=replace-with-another-long-random-secret-min-32-chars

# ── Database (used by docker-compose only) ───────────────────────────────────
POSTGRES_USER=codely
POSTGRES_PASSWORD=codely_secret
POSTGRES_DB=codely

# ── Code execution ───────────────────────────────────────────────────────────
# Docker Compose default — uses the piston service defined in compose.
# Override only if Piston runs elsewhere (e.g. separate host).
PISTON_URL=http://piston:2000/api/v2

# ── Frontend nginx — backend origin ──────────────────────────────────────────
# Docker Compose (default, set automatically via Dockerfile ENV):
#   BACKEND_URL=http://backend:3000
# External / custom deployment:
#   BACKEND_URL=https://your-backend-host
BACKEND_URL=http://backend:3000
